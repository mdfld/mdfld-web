generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(cuid())
  name             String
  email            String   @unique
  username         String   @unique
  displayUsername  String?
  emailVerified    Boolean  @default(false)
  image            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  twoFactorEnabled Boolean  @default(false)

  // Social/Profile fields
  bio      String?
  website  String?
  location String?
  banner   String?

  // Custom marketplace fields
  isVerifiedSeller Boolean   @default(false)
  trustScore       Float     @default(0.0)
  phoneNumber      String?
  dateOfBirth      DateTime?
  kycStatus        KycStatus @default(PENDING)
  role             UserRole  @default(BUYER)

  // Stripe customer fields
  stripeCustomerId String? @unique
  onboardingState  Json?   @default("{\"buyer\":[],\"seller\":[],\"tours\":[]}")

  // Relationships
  sessions      Session[]
  accounts      Account[]
  organizations OrganizationMember[]
  sellerProfile SellerProfile?
  buyerProfile  BuyerProfile?
  transactions  Transaction[]
  fraudReports  FraudReport[]
  auditLogs     AuditLog[]
  notifications Notification[]
  addresses     Address[]

  // Social relationships
  followers Follow[] @relation("UserFollows")
  following Follow[] @relation("UserFollowing")

  // Chat relationships
  conversations        ConversationParticipant[]
  messages             Message[]
  messageReceipts      MessageReceipt[]
  tradeOffersProposed TradeOffer[] @relation("TradeProposer")
  tradeOffersReceived TradeOffer[] @relation("TradeRecipient")

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Fraud detection fields
  deviceFingerprint String?
  location          String?
  isHighRisk        Boolean @default(false)

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  expiresAt             DateTime?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?

  @@map("account")
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
}

model Organization {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  logo        String?
  banner      String?
  description String?
  website     String?
  industry    String?
  size        CompanySize?
  metadata    Json?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Custom marketplace fields
  businessType    BusinessType @default(INDIVIDUAL)
  taxId           String?
  businessLicense String?
  isVerified      Boolean      @default(false)
  storeStatus     StoreStatus  @default(APPROVED)
  trustScore      Float        @default(0.0)

  // Address fields
  addressStreet   String?
  addressCity     String?
  addressState    String?
  addressZip      String?
  addressCountry  String?
  shipsFromCountry String?

  members       OrganizationMember[]
  invitations   OrganizationInvitation[]
  sellerProfile SellerProfile?
  products      Product[]
  orders        Order[]
  auditLogs     AuditLog[]
  
  // Messaging
  orgConversations OrgConversation[]

  @@map("organization")
}

model OrganizationMember {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  role           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@map("organization_member")
}

model OrganizationInvitation {
  id             String           @id @default(cuid())
  organizationId String
  email          String
  role           String
  status         InvitationStatus @default(PENDING)
  expiresAt      DateTime
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, email])
  @@map("organization_invitation")
}

model SellerProfile {
  id               String  @id @default(cuid())
  userId           String? @unique
  organizationId   String? @unique
  storeName        String
  storeDescription String?
  businessEmail    String
  businessPhone    String?
  taxNumber        String?
  payoutMethod      PayoutMethod?
  paypalEmail       String?
  stripeBankLast4   String?
  payoutSetupAt     DateTime?
  payoutRequestedAt DateTime?
  shippingPolicy   String?
  returnPolicy     String?
  averageRating    Float   @default(0.0)
  totalSales       Int     @default(0)
  isActive         Boolean @default(true)

  // Stripe Connect fields
  stripeAccountId         String?   @unique
  stripeAccountStatus     String?   // e.g., "active", "pending", "restricted"
  stripeOnboardingComplete Boolean  @default(false)
  stripeChargesEnabled    Boolean   @default(false)
  stripePayoutsEnabled    Boolean   @default(false)
  stripeRequirements      Json?     // Store any outstanding requirements
  stripeCapabilities      Json?     // Store capabilities like card_payments, transfers
  stripeDetailsSubmitted  Boolean   @default(false)
  stripeDefaultCurrency   String    @default("usd")
  
  // Commission settings
  commissionRate          Float     @default(0.10) // 10% default commission
  pendingBalance          Decimal   @default(0.00)
  settledBalance          Decimal   @default(0.00)
  lockedBalance           Decimal   @default(0.00)

  // Fraud detection metrics
  fraudScore              Float     @default(0.0)
  suspiciousActivityCount Int       @default(0)
  lastSuspiciousActivity  DateTime?
  accountAge              Int       @default(0) // days since account creation
  verificationLevel       Int       @default(0) // 0-5 scale

  // Shopify OAuth
  shopifyAccessToken    String?
  shopifyShopDomain     String?
  shopifyTokenExpiresAt DateTime?

  // eBay OAuth
  ebayAccessToken       String?
  ebayRefreshToken      String?
  ebayTokenExpiresAt    DateTime?

  user         User?         @relation(fields: [userId], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id])
  products     Product[]
  orders       Order[]
  reviews      Review[]
  fraudAlerts  FraudAlert[]
  importSessions ImportSession[]

  @@map("seller_profile")
}

model BuyerProfile {
  id                  String   @id @default(cuid())
  userId              String   @unique
  preferredCategories String[]
  wishlist            String[] // Product IDs
  averageOrderValue   Float    @default(0.0)
  totalOrders         Int      @default(0)

  // Fraud detection metrics
  fraudScore      Float @default(0.0)
  chargebackCount Int   @default(0)
  returnRate      Float @default(0.0)

  user           User            @relation(fields: [userId], references: [id])
  orders         Order[]
  reviews        Review[]
  cart           CartItem[]
  returnRequests ReturnRequest[]

  @@map("buyer_profile")
}

model Product {
  id              String   @id @default(cuid())
  sellerProfileId String
  organizationId  String?
  title           String
  description     String
  price           Decimal
  compareAtPrice  Decimal?
  category        ProductCategory
  subcategory     ProductSubcategory?
  brand           String?
  sku             String?  @unique
  inventory       Int      @default(0)
  weight          Float?
  dimensions      Json?
  images          String[]
  tags            String[]
  isActive        Boolean  @default(true)
  featured        Boolean  @default(false)
  verificationStatus ProductVerificationStatus @default(UNVERIFIED)

  // Variant support
  hasVariants      Boolean  @default(false)
  variantType      VariantType?
  
  // Product attributes - condition applies to all products
  condition        ProductCondition @default(BRAND_NEW)
  
  // Conditional fields based on category
  tier             ProductTier?
  year             Int?
  season           String?
  material         String?
  soleplateType    SoleplateType?
  playerVersion    PlayerVersion?

  // Collectible fields (COLLECTIBLES category only)
  collectibleCode       String?
  setName               String?
  collectiblePublisher  String?
  collectiblePlayerName String?
  collectibleTeam       String?
  isPeeled              Boolean?

  // Football fields (FOOTBALLS category only)
  ballSize              Int?
  ballGrade             BallGrade?

  // Stripe fields
  stripePriceId   String?  // Stripe Price object ID for this product
  stripeProductId String?  // Stripe Product object ID

  // Fraud detection fields
  priceChangeFrequency Int       @default(0)
  lastPriceChange      DateTime?
  reportCount          Int       @default(0)
  isHighRisk           Boolean   @default(false)
  tradeEnabled             Boolean   @default(false)

  // Shipping fields
  shippingTerms        ShippingTerms @default(CALCULATED)
  shippingCarrier      String?
  estimatedDeliveryDays Int?
  shipsFromCountry     String?       // overrides store default if set

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  seller       SellerProfile @relation(fields: [sellerProfileId], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id])
  orderItems   OrderItem[]
  reviews      Review[]
  cartItems    CartItem[]
  fraudReports FraudReport[]
  variants     ProductVariant[]
  sizeChart    SizeChart?
  tradeOfferRequests  TradeOffer[] @relation("RequestedProduct")
  tradeOffersMade     TradeOffer[] @relation("OfferedProduct")

  @@index([sellerProfileId])
  @@index([organizationId])
  @@index([isActive])
  @@index([category])
  @@index([createdAt])
  @@map("product")
}

model ProductVariant {
  id               String   @id @default(cuid())
  productId        String
  
  // Size fields (support multiple systems)
  sizeValue        String   // The actual size value (e.g., "9", "M", "28.5")
  sizeSystem       SizeSystem // UK, US, EU, etc.
  sizeDisplay      String   // Display value like "UK 9 / US 10 / EU 43"
  
  // Other variant attributes
  color            String?
  colorHex         String?
  sku              String?  @unique
  barcode          String?
  
  // Pricing and inventory per variant
  price            Decimal
  compareAtPrice   Decimal?
  inventory        Int      @default(0)
  lowStockAlert    Int?     @default(5)
  
  // Images specific to this variant
  images           String[]
  
  // Stripe integration
  stripePriceId    String?
  
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems       OrderItem[]
  cartItems        CartItem[]
  
  @@unique([productId, sizeValue, sizeSystem, color])
  @@map("product_variant")
}

model SizeChart {
  id              String   @id @default(cuid())
  productId       String   @unique
  chartType       SizeChartType
  conversions     Json     // Store size conversion data
  
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  @@map("size_chart")
}

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique
  buyerProfileId  String
  sellerProfileId String
  organizationId  String?
  status          OrderStatus   @default(PENDING)
  subtotal        Decimal
  tax             Decimal       @default(0)
  shipping        Decimal       @default(0)
  total           Decimal
  paymentMethod   PaymentMethod
  paymentStatus   PaymentStatus @default(PENDING)

  // Stripe fields
  stripePaymentIntentId String?   @unique
  stripeChargeId        String?
  stripeTransferId      String?   // For transfers to connected accounts
  applicationFeeAmount  Decimal?  // Platform commission amount
  stripeFeeAmount       Decimal?  // Stripe's processing fee
  
  // Fraud detection fields
  ipAddress            String?
  deviceFingerprint    String?
  riskScore            Float    @default(0.0)
  isHighRisk           Boolean  @default(false)
  fraudFlags           String[] @default([])
  verificationRequired Boolean  @default(false)

  shippingAddress Json
  billingAddress  Json
  notes           String?
  shippingMarkup   Decimal  @default(0)
  shippingService  String?

  // Tracking fields
  trackingNumber      String?
  trackingCarrier     String?
  trackingStatus      String?    // AfterShip tag: InfoReceived, InTransit, Delivered, etc.
  carrierConfirmedAt  DateTime?  // Set when carrier confirms pickup — unlocks the order's share of pendingBalance

  // EasyPost label fields
  easypostShipmentId  String?
  labelUrl            String?
  labelTrackingNumber String?
  labelCarrier        String?
  labelBoughtAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  buyer          BuyerProfile    @relation(fields: [buyerProfileId], references: [id])
  seller         SellerProfile   @relation(fields: [sellerProfileId], references: [id])
  organization   Organization?   @relation(fields: [organizationId], references: [id])
  items          OrderItem[]
  transactions   Transaction[]
  fraudAlerts    FraudAlert[]
  returnRequests ReturnRequest[]

  @@index([buyerProfileId])
  @@index([sellerProfileId])
  @@index([createdAt])
  @@map("order")
}

model OrderItem {
  id              String  @id @default(cuid())
  orderId         String
  productId       String
  variantId       String? // Optional for backward compatibility
  quantity        Int
  price           Decimal
  
  // Store variant details at time of order
  sizeDisplay     String?
  color           String?

  order           Order           @relation(fields: [orderId], references: [id])
  product         Product         @relation(fields: [productId], references: [id])
  variant         ProductVariant? @relation(fields: [variantId], references: [id])

  @@map("order_item")
}

model Transaction {
  id              String            @id @default(cuid())
  orderId         String?
  userId          String
  type            TransactionType
  amount          Decimal
  currency        String            @default("USD")
  status          TransactionStatus @default(PENDING)
  paymentMethod   PaymentMethod
  gatewayResponse Json?

  // Stripe fields
  stripeTransactionId String?  // Could be charge ID, refund ID, transfer ID, etc.
  stripeTransferId  String?
  paypalPayoutId    String?
  stripePaymentMethod String?  // Payment method ID used
  stripeFeeAmount     Decimal? // Stripe's processing fee
  netAmount           Decimal? // Amount after fees

  // Fraud detection fields
  ipAddress  String?
  userAgent  String?
  location   String?
  riskScore  Float    @default(0.0)
  fraudFlags String[] @default([])
  isHighRisk Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order Order? @relation(fields: [orderId], references: [id])
  user  User   @relation(fields: [userId], references: [id])

  @@map("transaction")
}

model FraudAlert {
  id              String         @id @default(cuid())
  orderId         String?
  sellerProfileId String?
  alertType       FraudAlertType
  severity        AlertSeverity
  description     String
  riskScore       Float
  status          AlertStatus    @default(ACTIVE)

  // Detection metadata
  triggerRules String[] @default([])
  metadata     Json?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  resolvedAt DateTime?

  order  Order?         @relation(fields: [orderId], references: [id])
  seller SellerProfile? @relation(fields: [sellerProfileId], references: [id])

  @@map("fraud_alert")
}

model ReturnRequest {
  id             String       @id @default(cuid())
  orderId        String
  buyerProfileId String
  reason         ReturnReason
  details        String
  status         ReturnStatus @default(PENDING)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  order       Order        @relation(fields: [orderId], references: [id])
  buyer       BuyerProfile @relation(fields: [buyerProfileId], references: [id])

  @@index([buyerProfileId])
  @@index([orderId])
  @@map("return_request")
}

model FraudReport {
  id          String          @id @default(cuid())
  reporterId  String
  productId   String?
  reportType  FraudReportType
  description String
  status      ReportStatus    @default(PENDING)
  priority    ReportPriority  @default(MEDIUM)

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  resolvedAt DateTime?

  reporter User     @relation(fields: [reporterId], references: [id])
  product  Product? @relation(fields: [productId], references: [id])

  @@map("fraud_report")
}

model RiskProfile {
  id              String     @id @default(cuid())
  entityType      EntityType // USER, SELLER, PRODUCT, TRANSACTION
  entityId        String
  riskScore       Float      @default(0.0)
  riskFactors     Json? // Detailed risk breakdown
  lastAssessment  DateTime   @default(now())
  assessmentCount Int        @default(1)

  // Historical risk tracking
  riskHistory Json[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([entityType, entityId])
  @@map("risk_profile")
}

model Address {
  id         String      @id @default(cuid())
  userId     String
  type       AddressType @default(SHIPPING)
  name       String
  street     String
  city       String
  state      String
  postalCode String
  country    String
  isDefault  Boolean     @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("address")
}

model Review {
  id              String  @id @default(cuid())
  productId       String
  buyerProfileId  String
  sellerProfileId String
  orderId         String?
  rating          Int // 1-5
  title           String?
  content         String
  isVerified      Boolean @default(false)
  isHelpful       Int     @default(0)

  // Fraud detection
  isSuspicious Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product       @relation(fields: [productId], references: [id])
  buyer   BuyerProfile  @relation(fields: [buyerProfileId], references: [id])
  seller  SellerProfile @relation(fields: [sellerProfileId], references: [id])

  @@map("review")
}

model CartItem {
  id             String  @id @default(cuid())
  buyerProfileId String
  productId      String
  variantId      String? // Optional for backward compatibility
  quantity       Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  buyer   BuyerProfile    @relation(fields: [buyerProfileId], references: [id])
  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@unique([buyerProfileId, productId, variantId])
  @@map("cart_item")
}

model AuditLog {
  id             String  @id @default(cuid())
  userId         String?
  organizationId String?
  action         String
  entityType     String
  entityId       String
  oldValues      Json?
  newValues      Json?
  ipAddress      String?
  userAgent      String?

  createdAt DateTime @default(now())

  user         User?         @relation(fields: [userId], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id])

  @@map("audit_log")
}

model Notification {
  id         String           @id @default(cuid())
  userId     String
  type       NotificationType
  title      String
  content    String
  isRead     Boolean          @default(false)
  isArchived Boolean          @default(false)
  metadata   Json?

  createdAt DateTime  @default(now())
  readAt    DateTime?

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([isRead])
  @@map("notification")
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String // User who follows
  followingId String // User being followed
  createdAt   DateTime @default(now())

  follower  User @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("UserFollows", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@map("follow")
}

enum KycStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  SELLER
  BUYER
}

enum StoreStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum BusinessType {
  INDIVIDUAL
  SMALL_BUSINESS
  CORPORATION
  NON_PROFIT
}

enum CompanySize {
  STARTUP
  SMALL
  MEDIUM
  LARGE
  ENTERPRISE
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  PAYPAL
  STRIPE
}

enum PayoutMethod {
  STRIPE_BANK
  PAYPAL
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  CANCELLED
  REFUNDED
}

enum TransactionType {
  PURCHASE
  REFUND
  FEE
  PAYOUT
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum FraudAlertType {
  SUSPICIOUS_TRANSACTION
  HIGH_RISK_USER
  FAKE_PRODUCT
  PRICE_MANIPULATION
  REVIEW_MANIPULATION
  ACCOUNT_TAKEOVER
  VELOCITY_CHECK
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertStatus {
  ACTIVE
  INVESTIGATING
  RESOLVED
  FALSE_POSITIVE
}

enum FraudReportType {
  FAKE_PRODUCT
  COUNTERFEIT
  PRICE_GOUGING
  MISLEADING_INFO
  SUSPICIOUS_SELLER
  OTHER
}

enum ReportStatus {
  PENDING
  IN_REVIEW
  RESOLVED
  DISMISSED
}

enum ReportPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum EntityType {
  USER
  SELLER
  PRODUCT
  TRANSACTION
  ORDER
}

enum AddressType {
  SHIPPING
  BILLING
  BOTH
}

enum NotificationType {
  ORDER_UPDATE
  PAYMENT_SUCCESS
  PAYMENT_FAILED
  FRAUD_ALERT
  REVIEW_RECEIVED
  SYSTEM_ANNOUNCEMENT
  NEW_MESSAGE
  MESSAGE_READ
  TRADE_OFFER_RECEIVED
  TRADE_OFFER_ACCEPTED
  TRADE_OFFER_DECLINED
  TRADE_OFFER_COUNTERED
  TRADE_OFFER_SHIPPED
  TRADE_OFFER_COMPLETED
  PAYOUT_COMPLETED
}

// Chat Models
model Conversation {
  id            String                    @id @default(cuid())
  type          ConversationType          @default(DIRECT)
  title         String?
  lastMessageId String?
  lastMessageAt DateTime?
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt

  participants    ConversationParticipant[]
  messages        Message[]
  orgConversation OrgConversation?
  tradeOffer      TradeOffer?

  @@map("conversation")
}

model ConversationParticipant {
  id                  String       @id @default(cuid())
  conversationId      String
  userId              String
  role                String       @default("member")
  joinedAt            DateTime     @default(now())
  lastReadAt          DateTime?
  lastReadMessageId   String?
  unreadCount         Int          @default(0)
  notificationsEnabled Boolean     @default(true)

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([conversationId, userId])
  @@index([userId, conversationId])
  @@map("conversation_participant")
}

model Message {
  id             String            @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  type           MessageType       @default(TEXT)
  metadata       Json?             // For attachments, links, etc.
  status         MessageStatus     @default(SENT)
  editedAt       DateTime?
  deletedAt      DateTime?
  createdAt      DateTime          @default(now())

  conversation   Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User              @relation(fields: [senderId], references: [id])
  receipts       MessageReceipt[]

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@map("message")
}

model MessageReceipt {
  id        String      @id @default(cuid())
  messageId String
  userId    String
  status    ReceiptStatus @default(DELIVERED)
  readAt    DateTime?
  createdAt DateTime    @default(now())

  message   Message     @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id])

  @@unique([messageId, userId])
  @@index([userId, messageId])
  @@map("message_receipt")
}

enum ConversationType {
  DIRECT
