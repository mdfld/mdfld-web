model ImportSession {
  id        String   @id @default(cuid())
  sellerId  String
  platform  String
  rows      Json
  expiresAt DateTime
  createdAt DateTime @default(now())

  seller SellerProfile @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([sellerId])
  @@map("import_session")
}

// Organization Messaging Models
model OrgConversation {
  id               String                @id @default(cuid())
  organizationId   String
  conversationId   String                @unique
  handledBy        String?               // Member ID handling the conversation
  category         String?               // Support category
  priority         ConversationPriority  @default(NORMAL)
  status           OrgConversationStatus @default(OPEN)
  notes            String?               // Internal notes
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  
  organization     Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversation     Conversation          @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  @@map("org_conversation")
}

enum ConversationPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TradeOfferStatus {
  PENDING
  COUNTERED
  AWAITING_PAYMENT
  ACCEPTED
  DECLINED
  CANCELLED
  SHIPPING
  COMPLETED
  EXPIRED
  DISPUTED
}

model TradeOffer {
  id                      String           @id @default(cuid())
  conversationId          String           @unique
  proposerId              String
  recipientId             String
  requestedProductId      String
  offeredProductId        String?
  cashAmount              Decimal?
  cashFromProposer        Boolean          @default(true)
  cashStripeSessionId     String?
  status                  TradeOfferStatus @default(PENDING)
  counterCashAmount       Decimal?
  counterById             String?

  proposerTrackingNumber  String?
  recipientTrackingNumber String?
  proposerShippedAt       DateTime?
  recipientShippedAt      DateTime?

  expiresAt               DateTime?
  completedAt             DateTime?
  cancelledAt             DateTime?

  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt

  conversation            Conversation     @relation(fields: [conversationId], references: [id])
  proposer                User             @relation("TradeProposer", fields: [proposerId], references: [id])
  recipient               User             @relation("TradeRecipient", fields: [recipientId], references: [id])
  requestedProduct        Product          @relation("RequestedProduct", fields: [requestedProductId], references: [id])
  offeredProduct          Product?         @relation("OfferedProduct", fields: [offeredProductId], references: [id])

  @@index([proposerId])
  @@index([recipientId])
  @@index([status])
  @@index([requestedProductId])
  @@index([status, expiresAt])
  @@map("trade_offer")
}

enum OrgConversationStatus {
  OPEN
  IN_PROGRESS
  WAITING_ON_USER
  WAITING_ON_ORG
  RESOLVED
  CLOSED
}

model PlatformSettings {
  id                  String   @id @default("singleton")
  sellerCommissionPct   Float    @default(0.10)
  buyerMarketplaceFee   Float    @default(0.00)
  shippingMarkupPct     Float    @default(0.15)
  shippingFlatRateCents Int      @default(899)
  updatedAt             DateTime @updatedAt
  updatedById         String?
}

model PlatformSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt

  @@map("platform_settings")
}
