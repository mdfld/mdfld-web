generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(cuid())
  name             String
  email            String   @unique
  username         String   @unique
  displayUsername  String?
  emailVerified    Boolean  @default(false)
  image            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  twoFactorEnabled Boolean  @default(false)

  // Social/Profile fields
  bio      String?
  website  String?
  location String?

  // Custom marketplace fields
  isVerifiedSeller Boolean   @default(false)
  trustScore       Float     @default(0.0)
  phoneNumber      String?
  dateOfBirth      DateTime?
  kycStatus        KycStatus @default(PENDING)

  // Relationships
  sessions      Session[]
  accounts      Account[]
  organizations OrganizationMember[]
  sellerProfile SellerProfile?
  buyerProfile  BuyerProfile?
  transactions  Transaction[]
  fraudReports  FraudReport[]
  auditLogs     AuditLog[]
  notifications Notification[]
  addresses     Address[]

  // Social relationships
  followers Follow[] @relation("UserFollows")
  following Follow[] @relation("UserFollowing")

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Fraud detection fields
  deviceFingerprint String?
  location          String?
  isHighRisk        Boolean @default(false)

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  expiresAt             DateTime?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?

  @@map("account")
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
}

model Organization {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  logo        String?
  description String?
  website     String?
  industry    String?
  size        CompanySize?
  metadata    Json?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Custom marketplace fields
  businessType    BusinessType @default(INDIVIDUAL)
  taxId           String?
  businessLicense String?
  isVerified      Boolean      @default(false)
  trustScore      Float        @default(0.0)

  members       OrganizationMember[]
  invitations   OrganizationInvitation[]
  sellerProfile SellerProfile?
  products      Product[]
  orders        Order[]
  auditLogs     AuditLog[]

  @@map("organization")
}

model OrganizationMember {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  role           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@map("organization_member")
}

model OrganizationInvitation {
  id             String           @id @default(cuid())
  organizationId String
  email          String
  role           String
  status         InvitationStatus @default(PENDING)
  expiresAt      DateTime
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, email])
  @@map("organization_invitation")
}

model SellerProfile {
  id               String  @id @default(cuid())
  userId           String? @unique
  organizationId   String? @unique
  storeName        String
  storeDescription String?
  businessEmail    String
  businessPhone    String?
  taxNumber        String?
  bankAccount      String?
  shippingPolicy   String?
  returnPolicy     String?
  averageRating    Float   @default(0.0)
  totalSales       Int     @default(0)
  isActive         Boolean @default(true)

  // Fraud detection metrics
  fraudScore              Float     @default(0.0)
  suspiciousActivityCount Int       @default(0)
  lastSuspiciousActivity  DateTime?
  accountAge              Int       @default(0) // days since account creation
  verificationLevel       Int       @default(0) // 0-5 scale

  user         User?         @relation(fields: [userId], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id])
  products     Product[]
  orders       Order[]
  reviews      Review[]
  fraudAlerts  FraudAlert[]

  @@map("seller_profile")
}

model BuyerProfile {
  id                  String   @id @default(cuid())
  userId              String   @unique
  preferredCategories String[]
  wishlist            String[] // Product IDs
  averageOrderValue   Float    @default(0.0)
  totalOrders         Int      @default(0)

  // Fraud detection metrics
  fraudScore      Float @default(0.0)
  chargebackCount Int   @default(0)
  returnRate      Float @default(0.0)

  user    User       @relation(fields: [userId], references: [id])
  orders  Order[]
  reviews Review[]
  cart    CartItem[]

  @@map("buyer_profile")
}

model Product {
  id              String   @id @default(cuid())
  sellerProfileId String
  organizationId  String?
  title           String
  description     String
  price           Decimal
  compareAtPrice  Decimal?
  category        String
  subcategory     String?
  brand           String?
  sku             String?  @unique
  inventory       Int      @default(0)
  weight          Float?
  dimensions      Json?
  images          String[]
  tags            String[]
  isActive        Boolean  @default(true)
  featured        Boolean  @default(false)

  // Fraud detection fields
  priceChangeFrequency Int       @default(0)
  lastPriceChange      DateTime?
  reportCount          Int       @default(0)
  isHighRisk           Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  seller       SellerProfile @relation(fields: [sellerProfileId], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id])
  orderItems   OrderItem[]
  reviews      Review[]
  cartItems    CartItem[]
  fraudReports FraudReport[]

  @@map("product")
}

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique
  buyerProfileId  String
  sellerProfileId String
  organizationId  String?
  status          OrderStatus   @default(PENDING)
  subtotal        Decimal
  tax             Decimal       @default(0)
  shipping        Decimal       @default(0)
  total           Decimal
  paymentMethod   PaymentMethod
  paymentStatus   PaymentStatus @default(PENDING)

  // Fraud detection fields
  ipAddress            String?
  deviceFingerprint    String?
  riskScore            Float    @default(0.0)
  isHighRisk           Boolean  @default(false)
  fraudFlags           String[] @default([])
  verificationRequired Boolean  @default(false)

  shippingAddress Json
  billingAddress  Json
  notes           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  buyer        BuyerProfile  @relation(fields: [buyerProfileId], references: [id])
  seller       SellerProfile @relation(fields: [sellerProfileId], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id])
  items        OrderItem[]
  transactions Transaction[]
  fraudAlerts  FraudAlert[]

  @@map("order")
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Decimal

  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@map("order_item")
}

model Transaction {
  id              String            @id @default(cuid())
  orderId         String?
  userId          String
  type            TransactionType
  amount          Decimal
  currency        String            @default("USD")
  status          TransactionStatus @default(PENDING)
  paymentMethod   PaymentMethod
  gatewayResponse Json?

  // Fraud detection fields
  ipAddress  String?
  userAgent  String?
  location   String?
  riskScore  Float    @default(0.0)
  fraudFlags String[] @default([])
  isHighRisk Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order Order? @relation(fields: [orderId], references: [id])
  user  User   @relation(fields: [userId], references: [id])

  @@map("transaction")
}

model FraudAlert {
  id              String         @id @default(cuid())
  orderId         String?
  sellerProfileId String?
  alertType       FraudAlertType
  severity        AlertSeverity
  description     String
  riskScore       Float
  status          AlertStatus    @default(ACTIVE)

  // Detection metadata
  triggerRules String[] @default([])
  metadata     Json?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  resolvedAt DateTime?

  order  Order?         @relation(fields: [orderId], references: [id])
  seller SellerProfile? @relation(fields: [sellerProfileId], references: [id])

  @@map("fraud_alert")
}

model FraudReport {
  id          String          @id @default(cuid())
  reporterId  String
  productId   String?
  reportType  FraudReportType
  description String
  status      ReportStatus    @default(PENDING)
  priority    ReportPriority  @default(MEDIUM)

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  resolvedAt DateTime?

  reporter User     @relation(fields: [reporterId], references: [id])
  product  Product? @relation(fields: [productId], references: [id])

  @@map("fraud_report")
}

model RiskProfile {
  id              String     @id @default(cuid())
  entityType      EntityType // USER, SELLER, PRODUCT, TRANSACTION
  entityId        String
  riskScore       Float      @default(0.0)
  riskFactors     Json? // Detailed risk breakdown
  lastAssessment  DateTime   @default(now())
  assessmentCount Int        @default(1)

  // Historical risk tracking
  riskHistory Json[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([entityType, entityId])
  @@map("risk_profile")
}

model Address {
  id         String      @id @default(cuid())
  userId     String
  type       AddressType @default(SHIPPING)
  name       String
  street     String
  city       String
  state      String
  postalCode String
  country    String
  isDefault  Boolean     @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("address")
}

model Review {
  id              String  @id @default(cuid())
  productId       String
  buyerProfileId  String
  sellerProfileId String
  orderId         String?
  rating          Int // 1-5
  title           String?
  content         String
  isVerified      Boolean @default(false)
  isHelpful       Int     @default(0)

  // Fraud detection
  isSuspicious Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product       @relation(fields: [productId], references: [id])
  buyer   BuyerProfile  @relation(fields: [buyerProfileId], references: [id])
  seller  SellerProfile @relation(fields: [sellerProfileId], references: [id])

  @@map("review")
}

model CartItem {
  id             String @id @default(cuid())
  buyerProfileId String
  productId      String
  quantity       Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  buyer   BuyerProfile @relation(fields: [buyerProfileId], references: [id])
  product Product      @relation(fields: [productId], references: [id])

  @@unique([buyerProfileId, productId])
  @@map("cart_item")
}

model AuditLog {
  id             String  @id @default(cuid())
  userId         String?
  organizationId String?
  action         String
  entityType     String
  entityId       String
  oldValues      Json?
  newValues      Json?
  ipAddress      String?
  userAgent      String?

  createdAt DateTime @default(now())

  user         User?         @relation(fields: [userId], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id])

  @@map("audit_log")
}

model Notification {
  id       String           @id @default(cuid())
  userId   String
  type     NotificationType
  title    String
  content  String
  isRead   Boolean          @default(false)
  metadata Json?

  createdAt DateTime  @default(now())
  readAt    DateTime?

  user User @relation(fields: [userId], references: [id])

  @@map("notification")
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String // User who follows
  followingId String // User being followed
  createdAt   DateTime @default(now())

  follower  User @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("UserFollows", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@map("follow")
}

enum KycStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
}

enum BusinessType {
  INDIVIDUAL
  SMALL_BUSINESS
  CORPORATION
  NON_PROFIT
}

enum CompanySize {
  STARTUP
  SMALL
  MEDIUM
  LARGE
  ENTERPRISE
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  PAYPAL
  STRIPE
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  CANCELLED
  REFUNDED
}

enum TransactionType {
  PURCHASE
  REFUND
  FEE
  PAYOUT
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum FraudAlertType {
  SUSPICIOUS_TRANSACTION
  HIGH_RISK_USER
  FAKE_PRODUCT
  PRICE_MANIPULATION
  REVIEW_MANIPULATION
  ACCOUNT_TAKEOVER
  VELOCITY_CHECK
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertStatus {
  ACTIVE
  INVESTIGATING
  RESOLVED
  FALSE_POSITIVE
}

enum FraudReportType {
  FAKE_PRODUCT
  COUNTERFEIT
  PRICE_GOUGING
  MISLEADING_INFO
  SUSPICIOUS_SELLER
  OTHER
}

enum ReportStatus {
  PENDING
  IN_REVIEW
  RESOLVED
  DISMISSED
}

enum ReportPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum EntityType {
  USER
  SELLER
  PRODUCT
  TRANSACTION
  ORDER
}

enum AddressType {
  SHIPPING
  BILLING
  BOTH
}

enum NotificationType {
  ORDER_UPDATE
  PAYMENT_SUCCESS
  PAYMENT_FAILED
  FRAUD_ALERT
  REVIEW_RECEIVED
  SYSTEM_ANNOUNCEMENT
}
